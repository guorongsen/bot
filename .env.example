# ====== 服务 ======
PORT=8787
# 可选：设置后，管理/交易相关 API 需要前端或请求方携带 X-Admin-Token
ADMIN_TOKEN=

# ====== 交易标的 ======
INST_ID=ETH-USDT-SWAP
# 拉取日线根数
KLINE_LIMIT=100

# ====== OKX ======
# 模拟盘: 1 (默认) / 实盘: 0
OKX_SIMULATED=1
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# REST 基址 (一般无需改)
OKX_REST_BASE=https://www.okx.com
# Optional: HTTP(S) proxy for Node fetch, e.g. http://127.0.0.1:7890
HTTPS_PROXY=

# ====== AI ======
# provider: openai | anthropic
AI_PROVIDER=openai
AI_MODEL=gpt-5.5
# OpenAI / OpenAI 兼容端点
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ====== 引擎 / 调度 ======
# 决策间隔(毫秒), 默认 1 小时
DECISION_INTERVAL_MS=3600000
# 启动时是否自动开始引擎: true/false
ENGINE_AUTOSTART=false

# ====== 风控护栏 ======
# 单笔最大下单金额(USDT 名义)
RISK_MAX_ORDER_USDT=100
# 总仓位上限(USDT 名义)
RISK_MAX_POSITION_USDT=500
# 强制止损 / 止盈 百分比 (0.05 = 5%)
RISK_STOP_LOSS_PCT=0.05
RISK_TAKE_PROFIT_PCT=0.1
# 决策冷却时间(毫秒)
RISK_COOLDOWN_MS=1800000
# 置信度阈值, 低于不执行
RISK_MIN_CONFIDENCE=0.6
# 合约杠杆
RISK_LEVERAGE=3
